NODE_ENV=production
FAMS_HOST=127.0.0.1
FAMS_PORT=4890
FAMS_DB_PATH=/var/lib/fams-dashboard/fams.db
FAMS_INGEST_KEY=replace_with_strong_random_key
# Optional: if set, webhook payload must include matching body_secret.
# FAMS_BODY_SECRET=replace_optional_body_secret
FAMS_LOG_LEVEL=info

# Local dev quickstart (without editing prod env file):
# NODE_ENV=development FAMS_INGEST_KEY=dev-local-key FAMS_DB_PATH=./fams-local.db FAMS_PORT=5900 npm run dev
